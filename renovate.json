{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base"
  ],
  "labels": [
    "dependencies"
  ],
  "timezone": "Asia/Kolkata",
  "schedule": [
    "before 5am on monday"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "gomod",
        "dockerfile",
        "github-actions",
        "helm-values"
      ],
      "groupName": "platform-dependencies"
    }
  ]
}

